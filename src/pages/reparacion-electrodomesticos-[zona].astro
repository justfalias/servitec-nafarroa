---
import Layout from '../layouts/Layout.astro'
import NavBar from '../components/NavBar.astro'
import { ZONAS_SEO } from '../data/zonas'

export async function getStaticPaths() {
  return ZONAS_SEO.map(z => ({ params: { zona: z.slug }, props: z }))
}

const PHONE = '634 006 304'
const PHONE_HREF = 'tel:+34634006304'
const WA_URL = 'https://wa.me/34634006304?text=%C2%A1Hola!%20He%20llegado%20a%20vosotros%20a%20trav%C3%A9s%20de%20servitecnafarroa.com%20y%20querr%C3%ADa%20saber%20m%C3%A1s%20sobre%20vuestros%20servicios.'

const { nombre, descripcionLarga, distanciaKm, codigoPostal, faq } = Astro.props
const slug = Astro.params.zona

const title = `Reparación de Electrodomésticos en ${nombre} | Servitec Nafarroa`
const description = `Técnico de electrodomésticos en ${nombre}, Navarra. Reparamos lavadoras, frigoríficos, lavavajillas, hornos y más. Servicio a domicilio el mismo día, 365 días. Llama: 634 006 304.`
const canonical = `https://www.servitecnafarroa.com/reparacion-electrodomesticos-${slug}/`

const SERVICIOS = [
  { nombre: 'Lavadoras',           slug: 'lavadoras',         icono: 'M3 12h18M3 6h18M3 18h18' },
  { nombre: 'Frigoríficos',        slug: 'frigorifico',       icono: 'M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zM8 10h8' },
  { nombre: 'Lavavajillas',        slug: 'lavavajillas',      icono: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z' },
  { nombre: 'Hornos',              slug: 'horno',             icono: 'M3 5h18v14H3zM3 10h18' },
  { nombre: 'Secadoras',           slug: 'secadora',          icono: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z' },
  { nombre: 'Vitrocerámicas',      slug: 'vitroceramica',     icono: 'M3 3h18v18H3z' },
  { nombre: 'Microondas',          slug: 'microondas',        icono: 'M4 5h16v14H4z' },
  { nombre: 'Campanas extractoras',slug: 'campana-extractora',icono: 'M3 3l18 18M3 21l18-18' },
  { nombre: 'Calentadores',        slug: 'calentador-agua',   icono: 'M12 2v20M2 12h20' },
]

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.servitecnafarroa.com/#business",
      "name": "Servitec Nafarroa",
      "telephone": "+34634006304",
      "url": "https://www.servitecnafarroa.com",
      "areaServed": [
        { "@type": "City", "name": "Pamplona" },
        { "@type": "City", "name": nombre },
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pamplona",
        "addressRegion": "Navarra",
        "addressCountry": "ES"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
}
---

<Layout {title} {description} {canonical}>
<style is:global>
  :root { --orange: #f97316; --blue: #1d4ed8; --dark: #0a0f1e; --mid: #111827; }
  * { box-sizing: border-box; }
  .btn-primary { display:inline-flex;align-items:center;gap:10px;background:#c2410c;color:white;font-weight:700;padding:16px 28px;border-radius:12px;font-size:1rem;text-decoration:none;transition:all .2s;box-shadow:0 6px 20px rgba(194,65,12,.35); }
  .btn-primary:hover { background:#9a3412;transform:translateY(-2px); }
  .btn-outline { display:inline-flex;align-items:center;gap:10px;background:transparent;color:white;font-weight:600;padding:16px 28px;border-radius:12px;font-size:1rem;text-decoration:none;border:1.5px solid rgba(255,255,255,.2);transition:all .2s; }
  .btn-outline:hover { background:rgba(255,255,255,.08); }
  .section-label { display:block;color:#c2410c;font-weight:700;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;margin-bottom:14px; }
  @media (max-width:768px) {
    .cta-row { flex-direction:column !important; }
    .cta-row a { width:100% !important; justify-content:center !important; }
    .servicios-grid { grid-template-columns:repeat(2,1fr) !important; }
    .faq-cols { grid-template-columns:1fr !important; }
    .badges-row { flex-direction:column !important; }
  }
</style>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<NavBar />

<!-- HERO -->
<section style="background:#0a0f1e;padding:80px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.02) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;"></div>
  <div style="max-width:1200px;margin:0 auto;position:relative;">
    <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(249,115,22,.12);border:1px solid rgba(249,115,22,.25);border-radius:100px;padding:6px 16px;margin-bottom:28px;">
      <span style="color:var(--orange);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;">{nombre} · Navarra · 365 días</span>
    </div>
    <h1 style="font-size:clamp(2rem,5vw,3.75rem);font-weight:900;color:white;line-height:1.1;letter-spacing:-.03em;margin-bottom:20px;max-width:800px;">
      Reparación de electrodomésticos<br/>en {nombre}
    </h1>
    <p style="font-size:1.05rem;color:#94a3b8;line-height:1.8;margin-bottom:40px;max-width:560px;">
      Técnicos multimarca a domicilio en {nombre}. Reparamos cualquier electrodoméstico el mismo día, incluidos fines de semana y festivos. Más de 20 años de experiencia en Navarra.
    </p>
    <div class="cta-row" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:48px;">
      <a href={PHONE_HREF} class="btn-primary" data-cta="llamar" data-location="hero">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
        Llamar ahora — {PHONE}
      </a>
      <a href={WA_URL} target="_blank" rel="noopener" class="btn-outline" data-cta="whatsapp" data-location="hero">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        WhatsApp
      </a>
    </div>
    <!-- Badges -->
    <div class="badges-row" style="display:flex;gap:24px;flex-wrap:wrap;">
      {[
        ['365 días/año', 'Incluidos festivos'],
        ['Mismo día', 'En la mayoría de casos'],
        [`A ${distanciaKm} km`, 'De Pamplona'],
        ['4,7 ★', '207 opiniones Google'],
      ].map(([val, label]) => (
        <div style="text-align:left;">
          <div style="color:white;font-weight:900;font-size:1.1rem;">{val}</div>
          <div style="color:#64748b;font-size:.78rem;">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SOBRE LA ZONA -->
<section style="padding:64px 24px;background:white;">
  <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" class="zona-grid">
    <div>
      <span class="section-label">Servicio en {nombre}</span>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#0a0f1e;letter-spacing:-.03em;margin-bottom:20px;">
        Técnicos de electrodomésticos en {nombre}
      </h2>
      <p style="color:#475569;line-height:1.9;font-size:.97rem;margin-bottom:24px;">
        {descripcionLarga}
      </p>
      <p style="color:#475569;line-height:1.9;font-size:.97rem;">
        Somos técnicos independientes multimarca — no somos el SAT oficial de ninguna marca, lo que nos permite ser más rápidos, más flexibles y más económicos. Trabajamos los <strong style="color:#0f172a;">365 días del año</strong>, de 8:00 a 20:00.
      </p>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px;">
      {[
        ['Desplazamiento + Diagnóstico + Presupuesto', '40 € + IVA'],
        ['Mano de obra', '20 € + IVA'],
        ['Disponibilidad', '365 días · 8:00–20:00'],
        ['Marcas', 'Todas — multimarca'],
      ].map(([concepto, valor]) => (
        <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 20px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;">
          <span style="color:#374151;font-size:.9rem;font-weight:500;">{concepto}</span>
          <span style="color:#1d4ed8;font-weight:800;font-size:.9rem;white-space:nowrap;">{valor}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  @media (max-width:768px) {
    .zona-grid { grid-template-columns:1fr !important; gap:32px !important; }
  }
</style>

<!-- SERVICIOS -->
<section style="padding:80px 24px;background:#f8fafc;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="section-label">Qué reparamos</span>
    <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:900;color:#0a0f1e;letter-spacing:-.03em;margin-bottom:40px;">
      Electrodomésticos que reparamos en {nombre}
    </h2>
    <div class="servicios-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:48px;">
      {SERVICIOS.map(s => (
        <a href={`/reparacion-${s.slug}-pamplona/`} style="display:flex;align-items:center;gap:14px;padding:20px;background:white;border:1px solid #e2e8f0;border-radius:14px;text-decoration:none;transition:all .2s;color:#374151;font-weight:600;font-size:.9rem;">
          <div style="width:36px;height:36px;background:#eff6ff;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={s.icono}/></svg>
          </div>
          {s.nombre}
        </a>
      ))}
    </div>
    <div style="background:linear-gradient(135deg,var(--blue),#1e40af);border-radius:20px;padding:32px 36px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:24px;">
      <div>
        <p style="color:white;font-size:1.1rem;font-weight:800;margin-bottom:6px;">¿Avería en {nombre}? Llamamos hoy.</p>
        <p style="color:rgba(255,255,255,.7);font-size:.9rem;">Diagnóstico a domicilio · Presupuesto sin compromiso</p>
      </div>
      <a href={PHONE_HREF} class="btn-primary" data-cta="llamar" data-location="servicios">Llamar: {PHONE}</a>
    </div>
  </div>
</section>

<!-- FAQ -->
<section style="padding:80px 24px;background:white;">
  <div style="max-width:1200px;margin:0 auto;">
    <span class="section-label">Preguntas frecuentes</span>
    <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:900;color:#0a0f1e;letter-spacing:-.03em;margin-bottom:40px;">
      Preguntas sobre el servicio en {nombre}
    </h2>
    <div class="faq-cols" style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
      {faq.map(f => (
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:16px;padding:28px;">
          <p style="font-weight:800;color:#0f172a;margin-bottom:12px;font-size:.95rem;">{f.q}</p>
          <p style="color:#64748b;font-size:.875rem;line-height:1.75;">{f.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA FINAL -->
<section style="padding:80px 24px;background:var(--dark);text-align:center;">
  <div style="max-width:600px;margin:0 auto;">
    <h2 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:900;color:white;letter-spacing:-.03em;margin-bottom:16px;">
      ¿Electrodoméstico averiado<br/>en {nombre}?
    </h2>
    <p style="color:#94a3b8;margin-bottom:36px;font-size:1rem;">
      Servicio a domicilio en {nombre} y toda Navarra. 365 días, festivos incluidos.
    </p>
    <div class="cta-row" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
      <a href={PHONE_HREF} class="btn-primary" data-cta="llamar" data-location="cta-final">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
        Llamar ahora
      </a>
      <a href={WA_URL} target="_blank" rel="noopener" class="btn-outline" data-cta="whatsapp" data-location="cta-final">WhatsApp</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer style="background:#020617;padding:32px 24px;text-align:center;">
  <div style="max-width:1200px;margin:0 auto;">
    <div style="margin-bottom:16px;">
      <img src="/servitec-nafarroa-logo-white.png" alt="Servitec Nafarroa" height="36" style="height:36px;width:auto;display:block;margin:0 auto;" />
      <p style="color:#94a3b8;font-size:.8rem;margin-top:4px;">Reparación de electrodomésticos · {nombre}, Navarra</p>
    </div>
    <div style="display:flex;justify-content:center;gap:20px;margin-bottom:16px;flex-wrap:wrap;">
      <a href={PHONE_HREF} style="color:#cbd5e1;font-size:.875rem;text-decoration:none;" data-cta="llamar" data-location="footer">{PHONE}</a>
      <a href={WA_URL} target="_blank" rel="noopener" style="color:#cbd5e1;font-size:.875rem;text-decoration:none;" data-cta="whatsapp" data-location="footer">WhatsApp</a>
      <a href="/" style="color:#cbd5e1;font-size:.875rem;text-decoration:none;">← Inicio</a>
    </div>
    <p style="color:#64748b;font-size:.75rem;">© {new Date().getFullYear()} Servitec Nafarroa · Todos los derechos reservados</p>
  </div>
</footer>
</Layout>
