<!-- MOBILE RESPONSIVE OVERRIDES -->
<style is:global>
@media (max-width: 768px) {
  /* Stats 2x2 */
  .stats-grid { grid-template-columns: 1fr 1fr !important; }
  .stat-card { padding: 24px 12px !important; }
  .stat-card .stat-num { font-size: 1.75rem !important; }
  .stat-card:nth-child(odd) { border-right: 1px solid rgba(255,255,255,.08) !important; }
  .stat-card:nth-child(1),.stat-card:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,.08) !important; }
  .stat-card:not(:last-child) { border-right: none !important; }

  /* About - stack */
  .about-grid { grid-template-columns: 1fr !important; gap: 24px !important; }
  .about-section { padding: 60px 0 !important; }

  /* Services - stack, hide images */
  .services-grid { grid-template-columns: 1fr !important; gap: 0 !important; }
  .services-sticky { position: static !important; padding-bottom: 32px; border-bottom: 2px solid #f1f5f9; margin-bottom: 32px; }
  .service-detail { grid-template-columns: 1fr !important; }
  .service-detail > div:last-child { display: none !important; }

  /* Reviews carousel */
  #rev-prev, #rev-next { display: none !important; }
  #rev-track { padding: 8px 16px 16px !important; }

  /* Booking - stack, hide cal */
  .booking-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  #cal-embed { min-height: 480px !important; }

  /* Process */
  #como-funciona > div > div:last-child { grid-template-columns: 1fr !important; gap: 28px !important; }

  /* Trust bar */
  #trust-bar { flex-wrap: wrap !important; gap: 10px !important; padding: 12px 16px !important; }

  /* CTA */
  #cta-buttons { flex-direction: column !important; align-items: stretch !important; }
  #cta-buttons a { justify-content: center !important; }

  /* Reviews header */
  #rev-header { flex-direction: column !important; align-items: flex-start !important; }

  /* Floating about card - fix overflow */
  #about-float { right: 0 !important; bottom: -12px !important; padding: 16px 20px !important; }
  #about-float .float-num { font-size: 1.75rem !important; }

  /* Footer */
  #footer-inner { flex-direction: column !important; align-items: center !important; text-align: center !important; gap: 12px !important; }
}

@media (max-width: 480px) {
  /* Extra small screens */
  .btn-primary, .btn-outline { padding: 14px 20px !important; font-size: .9rem !important; }
  .stats-grid .stat-num { font-size: 1.6rem !important; }
  #rev-track { padding: 8px 12px 16px !important; }
}

/* Mobile contact bar — visible solo en mobile */
@media (max-width: 768px) {
  .mobile-contact-bar { display: flex !important; }
  .wa-fab { display: none !important; }
  .md-hide { display: flex !important; }
  .md-flex { display: none !important; }
  /* Espacio para la barra fija inferior */
  body { padding-bottom: 82px; }
}

/* Desktop: ocultar barra mobile y mostrar nav links */
@media (min-width: 769px) {
  .mobile-contact-bar { display: none !important; }
  .md-hide { display: none !important; }
  .md-flex { display: flex !important; }
  .md-show { display: block !important; }
}
</style>
