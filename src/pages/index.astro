<script>
// Actualizar dots al hacer scroll
const track = document.getElementById('rev-track');
const dots = document.querySelectorAll('#rev-dots button');
if (track && dots.length) {
  track.addEventListener('scroll', () => {
    const idx = Math.round(track.scrollLeft / 356);
    dots.forEach((d, i) => {
      const active = i === idx;
      (d as HTMLElement).style.width = active ? '24px' : '8px';
      (d as HTMLElement).style.background = active ? '#1d4ed8' : '#cbd5e1';
    });
  }, { passive: true });
}
</script>

