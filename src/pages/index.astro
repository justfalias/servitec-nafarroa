<!-- HERO -->
<section style="background:#0a0f1e;min-height:92vh;display:flex;align-items:center;position:relative;overflow:hidden;">
  <!-- bg texture uniforme -->
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.02) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;"></div>

  <div style="max-width:1200px;margin:0 auto;padding:80px 24px;width:100%;">
    <div class="hero-grid" style="display:grid;grid-template-columns:1fr 480px;gap:64px;align-items:center;">

      <!-- Left -->
      <div>
        <!-- Social proof pill -->
        <div class="fade-up" style="display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:100px;padding:8px 18px;margin-bottom:36px;">
          <div style="display:flex;gap:2px;">
            {[1,2,3,4,5].map(() => <svg width="12" height="12" viewBox="0 0 24 24" fill="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>)}
          </div>
          <span style="color:#93c5fd;font-size:.8rem;font-weight:600;">4,7 · 207 opiniones en Google</span>
        </div>

        <h1 class="hero-h1" style="font-size:clamp(2rem,5.5vw,4.5rem);font-weight:900;color:white;line-height:1.1;letter-spacing:-.03em;margin-bottom:24px;text-wrap:balance;word-break:keep-all;overflow-wrap:break-word;">
          ¿Electrodoméstico<br/>roto? <span style="color:var(--orange);">Lo arreglamos<br/>hoy.</span>
        </h1>

        <p class="fade-up-3" style="font-size:1.1rem;color:#64748b;line-height:1.8;margin-bottom:40px;max-width:480px;">
          Técnicos independientes multimarca con <strong style="color:#94a3b8;">+20 años de experiencia</strong>. Servicio a domicilio en toda Navarra, incluso festivos.
        </p>

