---

<Layout>
<style is:global>
  * { box-sizing: border-box; }
  :root { --orange: #f97316; --blue: #1d4ed8; --dark: #0a0f1e; --mid: #111827; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-up { animation: fade-up .6s ease both; }
  .fade-up-2 { animation: fade-up .6s .15s ease both; }
  .fade-up-3 { animation: fade-up .6s .3s ease both; }

  details summary::-webkit-details-marker { display: none; }
  details summary { list-style: none; }
  details[open] .icon-plus { display: none; }
  details:not([open]) .icon-minus { display: none; }

  .service-item { border-bottom: 1px solid #e5e7eb; }
  .service-item:last-child { border-bottom: none; }
  .service-item summary { padding: 20px 0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .service-item summary:hover h3 { color: var(--orange); }
  .service-detail { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding-bottom: 24px; }

  .stat-card { text-align: center; padding: 36px 20px; }
  .stat-card:not(:last-child) { border-right: 1px solid rgba(255,255,255,.08); }

  .btn-primary { display: inline-flex; align-items: center; gap: 10px; background: var(--orange); color: white; font-weight: 700; padding: 16px 28px; border-radius: 12px; font-size: 1rem; text-decoration: none; transition: all .2s; box-shadow: 0 6px 20px rgba(249,115,22,.35); }
  .btn-primary:hover { background: #ea580c; transform: translateY(-2px); }
  .btn-outline { display: inline-flex; align-items: center; gap: 10px; background: transparent; color: white; font-weight: 600; padding: 16px 28px; border-radius: 12px; font-size: 1rem; text-decoration: none; border: 1.5px solid rgba(255,255,255,.2); transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); }

  .section-label { display: block; color: var(--orange); font-weight: 700; font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 14px; }
  .section-title { font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 900; letter-spacing: -.03em; line-height: 1.1; color: #0a0f1e; }
  .section-title.light { color: white; }

  /* GRID HELPERS */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .grid-2-equal { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: center; }

  /* ============ MOBILE ============ */
  @media (max-width: 768px) {
    /* Stats bar: 2x2 */
    .stats-grid { grid-template-columns: 1fr 1fr !important; }
    .stat-card { padding: 24px 16px !important; }
    .stat-card:not(:last-child) { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,.08) !important; }
    .stat-card:nth-child(1), .stat-card:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,.08) !important; }
    .stat-card:nth-child(odd) { border-right: 1px solid rgba(255,255,255,.08) !important; }

    /* Hero */
    .hero-img-block { display: none !important; }
    .hero-section { padding: 48px 0 !important; min-height: unset !important; }
    .hero-content { gap: 20px !important; }

    /* About */
    .about-section { padding: 60px 0 !important; }
    .about-grid { grid-template-columns: 1fr !important; gap: 48px !important; }
    .about-img-wrap { max-height: 320px !important; }
    .about-float-card { right: 0 !important; bottom: -16px !important; }

    /* Services */
    .services-section { padding: 60px 0 !important; }
    .services-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .services-sticky { position: static !important; }
    .service-detail { grid-template-columns: 1fr !important; }
    .service-detail img { display: none !important; }

    /* Reviews */
    .reviews-section { padding: 60px 0 60px !important; }
    .reviews-header { flex-direction: column !important; align-items: flex-start !important; }
    #rev-track { padding: 8px 20px 20px !important; }
    #rev-prev, #rev-next { display: none !important; }

    /* Booking */
    .booking-section { padding: 60px 0 !important; }
    .booking-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .booking-info-items { gap: 12px !important; }

    /* How it works */
    .process-grid { grid-template-columns: 1fr !important; gap: 32px !important; }

    /* CTA */
    .cta-section { padding: 64px 0 !important; }
    .cta-buttons { flex-direction: column !important; align-items: center !important; }
    .cta-buttons a { width: 100% !important; justify-content: center !important; }

    /* Footer */
    .footer-inner { flex-direction: column !important; align-items: center !important; text-align: center !important; }

    /* Brands */
    .brands-wrap { gap: 10px !important; }

    /* Trust badges */
    .trust-bar { gap: 12px !important; padding: 14px 16px !important; }
    .trust-bar span { font-size: .75rem !important; }

    /* Nav */
    .nav-phone { display: none !important; }

    /* Sections padding */
    .section-pad { padding: 64px 0 !important; }

    /* FAQ */
    .faq-section { padding: 60px 0 !important; }

    /* Zones */
    .zones-section { padding: 48px 0 !important; }

    /* General text scaling */
    .section-title { font-size: clamp(1.6rem, 6vw, 2.5rem) !important; }
    .hero-h1 { font-size: clamp(1.9rem, 8vw, 3.5rem) !important; }

    /* Scrollbar hide on track */
    #rev-track::-webkit-scrollbar { display: none; }

    /* Rating box mobile */
    .rating-box { padding: 16px 20px !important; }
    .rating-box .rating-num { font-size: 2.25rem !important; }
  }
</style>

<!-- NAV -->
<header style="position:sticky;top:0;z-index:50;background:white;border-bottom:1px solid #f1f5f9;backdrop-filter:blur(12px);">
