---
import { ELECTRODOMESTICOS } from '../data/electrodomesticos'
import { MARCAS_SEO } from '../data/marcas'

const PHONE = '634 006 304'
const PHONE_HREF = 'tel:+34634006304'
const WA_URL = 'https://wa.me/34634006304?text=%C2%A1Hola!%20He%20llegado%20a%20vosotros%20a%20trav%C3%A9s%20de%20servitecnafarroa.com%20y%20querr%C3%ADa%20saber%20m%C3%A1s%20sobre%20vuestros%20servicios.'
---

<style is:global>
  /* ===== NAV DROPDOWNS ===== */
  .nav-dd { position: relative; }
  .nav-dd-btn {
    display: flex; align-items: center; gap: 5px;
    color: #475569; font-size: .875rem; font-weight: 500;
    padding: 8px 12px; background: none; border: none; cursor: pointer;
    border-radius: 8px; transition: background .15s, color .15s;
    font-family: inherit;
  }
  .nav-dd-btn:hover { background: #f8fafc; color: #0f172a; }
  .nav-dd-btn svg { transition: transform .2s; }
  .nav-dd:hover .nav-dd-btn svg { transform: rotate(180deg); }
  .nav-dd-panel {
    position: absolute; top: calc(100% + 6px); left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: white; border: 1px solid #e2e8f0; border-radius: 16px;
    padding: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.12);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .18s, transform .18s, visibility .18s;
    min-width: 220px; z-index: 100;
  }
  .nav-dd:hover .nav-dd-panel {
    opacity: 1; visibility: visible; pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav-dd-panel a {
    display: block; padding: 8px 12px; border-radius: 10px;
    color: #374151; font-size: .82rem; font-weight: 500; text-decoration: none;
    transition: background .12s, color .12s; white-space: nowrap;
  }
  .nav-dd-panel a:hover { background: #f1f5f9; color: #1d4ed8; }
  .nav-dd-panel .dd-section {
    font-size: .65rem; font-weight: 700; color: #475569;
    letter-spacing: .1em; text-transform: uppercase;
    padding: 6px 12px 4px; display: block;
  }
  .nav-dd-panel-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 0 4px; min-width: 340px; }

  /* ===== HAMBURGER / MOBILE MENU ===== */
  .ham-btn {
    display: none; align-items: center; justify-content: center;
    width: 40px; height: 40px; background: #f8fafc; border: 1.5px solid #e2e8f0;
    border-radius: 12px; cursor: pointer; color: #374151;
  }
  @media (max-width: 768px) { .ham-btn { display: flex; } }

  .mobile-menu-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.4);
    z-index: 200; opacity: 0; visibility: hidden;
    transition: opacity .25s, visibility .25s;
  }
  .mobile-menu-overlay.open { opacity: 1; visibility: visible; }
  .mobile-menu-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; width: min(340px, 90vw);
    background: white; z-index: 201; overflow-y: auto;
    transform: translateX(100%); transition: transform .28s ease;
    padding: 0 0 32px;
  }
  .mobile-menu-overlay.open .mobile-menu-drawer { transform: translateX(0); }
  .mob-menu-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px; border-bottom: 1px solid #f1f5f9; position: sticky; top: 0;
    background: white; z-index: 1;
  }
  .mob-menu-close {
    width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
    border: none; background: #f8fafc; border-radius: 10px; cursor: pointer; color: #374151;
  }
  .mob-section-title {
    font-size: .65rem; font-weight: 700; color: #475569; letter-spacing: .1em;
    text-transform: uppercase; padding: 16px 20px 8px; display: block;
  }
  .mob-link {
    display: block; padding: 10px 20px; color: #374151; font-size: .9rem;
    font-weight: 500; text-decoration: none; transition: background .12s;
  }
  .mob-link:hover { background: #f8fafc; color: #1d4ed8; }
  .mob-sep { height: 1px; background: #f1f5f9; margin: 8px 20px; }

  /* Desktop show/hide helpers (shared) */
  @media (min-width: 769px) {
    .nav-md-hide { display: none !important; }
    .nav-md-show { display: block !important; }
    .nav-md-flex { display: flex !important; }
  }
  @media (max-width: 768px) {
    .nav-md-hide { display: flex !important; }
    .nav-md-show { display: none !important; }
    .nav-md-flex { display: none !important; }
  }
</style>

<!-- NAV -->
<header style="position:sticky;top:0;z-index:50;background:white;border-bottom:1px solid #f1f5f9;backdrop-filter:blur(12px);">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;height:68px;display:flex;align-items:center;justify-content:space-between;">
    <a href="/" aria-label="Servitec Nafarroa — Inicio" style="display:flex;align-items:center;gap:12px;text-decoration:none;">
      <div style="width:40px;height:40px;background:#1d4ed8;border-radius:12px;display:flex;align-items:center;justify-content:center;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </div>
      <div>
        <div style="font-size:1.05rem;font-weight:900;line-height:1;letter-spacing:-.01em;">
          <span style="color:#1d4ed8;">SERVITEC</span> <span style="color:#f97316;">NAFARROA</span>
        </div>
        <div style="font-size:.6rem;color:#475569;letter-spacing:.08em;text-transform:uppercase;margin-top:2px;">Servicio técnico · Navarra</div>
      </div>
    </a>
    <nav style="display:flex;align-items:center;gap:4px;">
      <!-- Desktop links + dropdowns -->
      <a href="/#servicios" style="color:#475569;font-size:.875rem;font-weight:500;padding:8px 12px;text-decoration:none;display:none;border-radius:8px;" class="nav-md-show">Servicios</a>
      <a href="/#tarifas" style="color:#475569;font-size:.875rem;font-weight:500;padding:8px 12px;text-decoration:none;display:none;border-radius:8px;" class="nav-md-show">Tarifas</a>
      <a href="/#opiniones" style="color:#475569;font-size:.875rem;font-weight:500;padding:8px 12px;text-decoration:none;display:none;border-radius:8px;" class="nav-md-show">Opiniones</a>

      <!-- Dropdown: Electrodomésticos -->
      <div class="nav-dd nav-md-show" style="display:none;">
        <button class="nav-dd-btn">
          Electrodomésticos
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nav-dd-panel">
          <span class="dd-section">Por tipo de electrodoméstico</span>
          {ELECTRODOMESTICOS.map(e => (
            <a href={`/reparacion-${e.slug}-pamplona/`}>{e.nombrePlural ?? e.nombre}</a>
          ))}
        </div>
      </div>

      <!-- Dropdown: Marcas -->
      <div class="nav-dd nav-md-show" style="display:none;">
        <button class="nav-dd-btn">
          Marcas
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="nav-dd-panel nav-dd-panel-2col">
          <span class="dd-section" style="grid-column:1/-1;">Por marca</span>
          {MARCAS_SEO.map(m => (
            <a href={`/servicio-tecnico-${m.slug}-pamplona/`}>{m.nombre}</a>
          ))}
        </div>
      </div>

      <!-- Desktop: llamar + WhatsApp -->
      <div style="display:none;align-items:center;gap:6px;margin-left:8px;" class="nav-md-flex">
        <a href={PHONE_HREF} style="display:flex;align-items:center;gap:6px;color:#0f172a;font-size:.875rem;font-weight:700;padding:9px 14px;text-decoration:none;border:1.5px solid #e2e8f0;border-radius:10px;transition:background .15s;" data-cta="llamar" data-location="nav">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
          {PHONE}
        </a>
        <a href={WA_URL} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:7px;background:#22c55e;color:white;font-size:.875rem;font-weight:700;padding:9px 16px;border-radius:10px;text-decoration:none;" data-cta="whatsapp" data-location="nav">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          WhatsApp
        </a>
      </div>

      <!-- Mobile: llamar + whatsapp + hamburguesa -->
      <a href={PHONE_HREF} aria-label="Llamar: 634 006 304" class="nav-md-hide" style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;background:#1d4ed8;border-radius:12px;color:white;" data-cta="llamar" data-location="nav">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
      </a>
      <a href={WA_URL} aria-label="WhatsApp" target="_blank" rel="noopener" class="nav-md-hide" style="display:flex;align-items:center;justify-content:center;width:40px;height:40px;background:#22c55e;border-radius:12px;color:white;" data-cta="whatsapp" data-location="nav">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
      </a>
      <button id="ham-btn" class="ham-btn" aria-label="Abrir menú">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </nav>
  </div>
</header>

<!-- MOBILE MENU DRAWER -->
<div id="mob-overlay" class="mobile-menu-overlay" aria-hidden="true">
  <div class="mobile-menu-drawer" role="dialog" aria-label="Menú de navegación">
    <div class="mob-menu-head">
      <div style="font-size:.85rem;font-weight:700;color:#0f172a;">Menú</div>
      <button id="mob-close" class="mob-menu-close" aria-label="Cerrar menú">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <span class="mob-section-title">Electrodomésticos</span>
    {ELECTRODOMESTICOS.map(e => (
      <a href={`/reparacion-${e.slug}-pamplona/`} class="mob-link">{e.nombrePlural ?? e.nombre}</a>
    ))}

    <div class="mob-sep"></div>
    <span class="mob-section-title">Marcas</span>
    <div style="display:grid;grid-template-columns:1fr 1fr;">
      {MARCAS_SEO.map(m => (
        <a href={`/servicio-tecnico-${m.slug}-pamplona/`} class="mob-link">{m.nombre}</a>
      ))}
    </div>

    <div class="mob-sep"></div>
    <span class="mob-section-title">Navegación</span>
    <a href="/#servicios" class="mob-link">Servicios</a>
    <a href="/#tarifas" class="mob-link">Tarifas</a>
    <a href="/#opiniones" class="mob-link">Opiniones</a>

    <div style="padding:16px 20px 0;">
      <a href={PHONE_HREF} style="display:flex;align-items:center;justify-content:center;gap:8px;background:#1d4ed8;color:white;font-weight:700;padding:14px;border-radius:12px;text-decoration:none;font-size:.9rem;margin-bottom:10px;" data-cta="llamar" data-location="mobile-menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 3h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.66 18l.26-1.08z"/></svg>
        Llamar: {PHONE}
      </a>
      <a href={WA_URL} target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;gap:8px;background:#22c55e;color:white;font-weight:700;padding:14px;border-radius:12px;text-decoration:none;font-size:.9rem;" data-cta="whatsapp" data-location="mobile-menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
        WhatsApp
      </a>
    </div>
  </div>
</div>

<script>
  const overlay  = document.getElementById('mob-overlay')!;
  const hamBtn   = document.getElementById('ham-btn')!;
  const closeBtn = document.getElementById('mob-close')!;
  function openMenu()  { overlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeMenu() { overlay.classList.remove('open'); document.body.style.overflow = ''; }
  hamBtn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeMenu(); });
  overlay.querySelectorAll('a[href^="/"]').forEach(a => a.addEventListener('click', closeMenu));
</script>
