---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
}

const {
  title = 'Reparación de Electrodomésticos en Pamplona | Servitec Nafarroa',
  description = 'Servicio técnico especializado en reparación de electrodomésticos en Pamplona y Navarra. Siemens, Bosch, Balay y más marcas. Visita a domicilio. Presupuesto gratuito. Reserva online.',
  canonical = 'https://servitecnafarroa.com',
} = Astro.props

const ogImage = 'https://servitecnafarroa.com/og-image.png'

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://servitecnafarroa.com/#business",
      "name": "Servitec Nafarroa",
      "alternateName": "Servitec Nafarroa Servicio Técnico Pamplona",
      "description": "Servicio técnico especializado en reparación de electrodomésticos en Pamplona y Navarra. Especialistas en Siemens, Bosch y Balay.",
      "url": "https://servitecnafarroa.com",
      "telephone": "+34634006304",
      "priceRange": "€€",
      "image": ogImage,
      "logo": ogImage,
      "areaServed": [
        { "@type": "City", "name": "Pamplona", "sameAs": "https://www.wikidata.org/wiki/Q10282" },
        { "@type": "City", "name": "Barañáin" },
        { "@type": "City", "name": "Burlada" },
        { "@type": "City", "name": "Huarte" },
        { "@type": "City", "name": "Villava" },
        { "@type": "AdministrativeArea", "name": "Navarra", "sameAs": "https://www.wikidata.org/wiki/Q10282" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pamplona",
        "addressRegion": "Navarra",
        "postalCode": "31001",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "42.8169",
        "longitude": "-1.6432"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
          "opens": "08:00",
          "closes": "20:00"
        }
      ],
      "sameAs": [
        "https://www.servitecnafarroa.com"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Reparación de electrodomésticos en Pamplona",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de lavadoras en Pamplona", "description": "Reparamos lavadoras de todas las marcas en Pamplona y Navarra a domicilio." }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de frigoríficos en Pamplona", "description": "Servicio técnico de frigoríficos y congeladores en Pamplona." }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de lavavajillas en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de hornos en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de secadoras en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación electrodomésticos Siemens Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación electrodomésticos Bosch Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación electrodomésticos Balay Pamplona" }}
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.7",
        "reviewCount": "207",
        "bestRating": "5",
        "worstRating": "1"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Juan Pablo Carretero" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "Llamé un domingo a primera hora porque la lavadora dejó de funcionar, y a las dos horas lo tenía aquí. Denis súper majo y atento siempre. Muy profesional."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Silvia Perete" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
          "reviewBody": "Un domingo se me estropeó la lavadora, llamé y en media hora estaba el técnico en mi casa. Persona encantadora y amable, precio muy bueno para ser domingo."
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta reparar una lavadora en Pamplona?",
          "acceptedAnswer": { "@type": "Answer", "text": "El diagnóstico es gratuito y sin compromiso. La mayoría de reparaciones de lavadora en Pamplona están entre 60€ y 180€ incluyendo mano de obra y piezas." }
        },
        {
          "@type": "Question",
          "name": "¿Reparáis electrodomésticos Siemens en Pamplona?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí, somos especialistas en la reparación de electrodomésticos Siemens, Bosch y Balay en Pamplona y toda Navarra. También reparamos Miele, AEG, Electrolux, Samsung, LG y más marcas." }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tarda la reparación?",
          "acceptedAnswer": { "@type": "Answer", "text": "El 90% de las reparaciones se resuelven en la primera visita a domicilio. Trabajamos con piezas originales y de calidad." }
        },
        {
          "@type": "Question",
          "name": "¿Dais garantía en las reparaciones?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí, todas nuestras reparaciones incluyen garantía de 3 meses en piezas y mano de obra." }
        },
        {
          "@type": "Question",
          "name": "¿A qué zonas de Navarra llegáis?",
          "acceptedAnswer": { "@type": "Answer", "text": "Cubrimos Pamplona y toda el área metropolitana: Barañáin, Burlada, Huarte, Villava, Ansoáin, Zizur Mayor, Berriozar, Cizur, Noáin, Sarriguren, Beriáin y más municipios de Navarra." }
        },
        {
          "@type": "Question",
          "name": "¿Se puede reservar visita online?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí, puedes reservar tu visita técnica directamente online eligiendo día y hora. También puedes contactar por WhatsApp o teléfono." }
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://servitecnafarroa.com/#website",
      "url": "https://servitecnafarroa.com",
      "name": "Servitec Nafarroa",
      "description": "Servicio técnico de electrodomésticos en Pamplona y Navarra",
      "inLanguage": "es-ES",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://servitecnafarroa.com/?s={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  ]
}
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Servitec Nafarroa" />
    <meta name="geo.region" content="ES-NC" />
    <meta name="geo.placename" content="Pamplona, Navarra" />
    <meta name="geo.position" content="42.8169;-1.6432" />
    <meta name="ICBM" content="42.8169, -1.6432" />

    <!-- Keywords -->
    <meta name="keywords" content="reparación electrodomésticos Pamplona, servicio técnico Siemens Pamplona, reparar lavadora Pamplona, técnico electrodomésticos Navarra, reparación Bosch Pamplona, reparación Balay Pamplona, servicio técnico electrodomésticos Navarra, reparación frigorífico Pamplona, reparación lavavajillas Pamplona, reparación horno Pamplona" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Servitec Nafarroa - Reparación de electrodomésticos en Pamplona" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Servitec Nafarroa" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Servitec Nafarroa - Reparación de electrodomésticos en Pamplona" />

    <!-- WhatsApp / Telegram preview -->
    <meta property="og:image:type" content="image/png" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.google.com" />
  </head>
  <body>
    <slot />
  </body>
</html>
