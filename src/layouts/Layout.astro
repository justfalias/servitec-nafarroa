---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
}

const {
  title = 'Reparación de Electrodomésticos Pamplona | Servitec Nafarroa — +20 años, 365 días',
  description = 'Técnicos multimarca con +20 años de experiencia en Pamplona y toda Navarra. Reparamos Siemens, Bosch, Balay, Miele, AEG y más. Servicio a domicilio 365 días, festivos incluidos. Llámanos: 634 006 304.',
  canonical = 'https://www.servitecnafarroa.com/',
} = Astro.props

const ogImage = 'https://www.servitecnafarroa.com/og-image.png'

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.servitecnafarroa.com/#business",
      "name": "Servitec Nafarroa",
      "alternateName": ["Servitec Nafarroa SAT", "Servicio Técnico Electrodomésticos Pamplona"],
      "description": "Servicio técnico independiente multimarca especializado en reparación de electrodomésticos en Pamplona y toda Navarra. +20 años de experiencia. Disponible 365 días.",
      "url": "https://www.servitecnafarroa.com",
      "telephone": "+34634006304",
      "priceRange": "€€",
      "image": ogImage,
      "logo": ogImage,
      "areaServed": [
        { "@type": "City", "name": "Pamplona" },
        { "@type": "City", "name": "Barañáin" },
        { "@type": "City", "name": "Burlada" },
        { "@type": "City", "name": "Huarte" },
        { "@type": "City", "name": "Villava" },
        { "@type": "City", "name": "Ansoáin" },
        { "@type": "City", "name": "Zizur Mayor" },
        { "@type": "City", "name": "Berriozar" },
        { "@type": "City", "name": "Noáin" },
        { "@type": "City", "name": "Sarriguren" },
        { "@type": "AdministrativeArea", "name": "Navarra" }
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pamplona",
        "addressRegion": "Navarra",
        "postalCode": "31011",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "42.8169",
        "longitude": "-1.6432"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "08:00",
        "closes": "20:00"
      },
      "sameAs": ["https://www.servitecnafarroa.com"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Reparación de electrodomésticos en Pamplona",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de lavadoras en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de frigoríficos en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de lavavajillas en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de hornos en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación de secadoras en Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación electrodomésticos Siemens Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación electrodomésticos Bosch Pamplona" }},
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Reparación electrodomésticos Balay Pamplona" }}
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.7",
        "reviewCount": "207",
        "bestRating": "5"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta reparar una lavadora en Pamplona?",
          "acceptedAnswer": { "@type": "Answer", "text": "La intervención mínima (desplazamiento + diagnóstico + presupuesto) tiene un coste de 40€ + IVA. La mano de obra de reparación son 20€ + IVA más el coste del repuesto según fabricante. La mayoría de reparaciones están entre 60€ y 180€." }
        },
        {
          "@type": "Question",
          "name": "¿Reparáis electrodomésticos Siemens, Bosch y Balay en Pamplona?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí, somos especialistas en Siemens, Bosch y Balay. También reparamos Miele, AEG, Electrolux, Samsung, LG, Fagor, Beko, Zanussi, Teka, Edesa, Cata y más marcas en Pamplona y toda Navarra." }
        },
        {
          "@type": "Question",
          "name": "¿Trabajáis festivos y fines de semana?",
          "acceptedAnswer": { "@type": "Answer", "text": "Sí. Disponibles los 365 días del año, incluyendo festivos y fines de semana. Un electrodoméstico averiado no entiende de calendarios." }
        },
        {
          "@type": "Question",
          "name": "¿A qué zonas de Navarra llegáis?",
          "acceptedAnswer": { "@type": "Answer", "text": "Cubrimos Pamplona y toda Navarra: Barañáin, Burlada, Huarte, Villava, Ansoáin, Zizur Mayor, Berriozar, Cizur, Noáin, Sarriguren, Beriáin y más municipios." }
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://www.servitecnafarroa.com/#website",
      "url": "https://www.servitecnafarroa.com",
      "name": "Servitec Nafarroa",
      "inLanguage": "es-ES"
    }
  ]
}
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Servitec Nafarroa" />
    <meta name="geo.region" content="ES-NC" />
    <meta name="geo.placename" content="Pamplona, Navarra" />
    <meta name="geo.position" content="42.8169;-1.6432" />
    <meta name="ICBM" content="42.8169, -1.6432" />
    <meta name="keywords" content="reparación electrodomésticos Pamplona, servicio técnico Siemens Pamplona, reparar lavadora Pamplona, técnico electrodomésticos Navarra, reparación Bosch Pamplona, reparación Balay Pamplona, servicio técnico electrodomésticos festivos Navarra, reparación frigorífico Pamplona, técnico Pamplona 365 días" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content="Reparación de Electrodomésticos en Pamplona — Servitec Nafarroa" />
    <meta property="og:description" content="Técnicos multimarca con +20 años de experiencia. Servicio a domicilio en toda Navarra, 365 días al año, festivos incluidos. 4,7★ · 207 opiniones Google." />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Servitec Nafarroa — Reparación de electrodomésticos en Pamplona, 365 días" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Servitec Nafarroa" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Reparación de Electrodomésticos en Pamplona — Servitec Nafarroa" />
    <meta name="twitter:description" content="Técnicos multimarca con +20 años de experiencia en Navarra. Disponibles 365 días, festivos incluidos." />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicon completo -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1d4ed8" />
    <meta name="msapplication-TileColor" content="#1d4ed8" />

    <!-- Sitemap hint -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Preload LCP image -->
    <link rel="preload" as="image" href="/tecnico-hero.webp" fetchpriority="high" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
